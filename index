  const PASSWORD = "aurum2024";

  function tryLogin() {
    const val = document.getElementById('pw').value;
    if (val === PASSWORD) {
      sessionStorage.setItem('aurum_ok', '1');
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('main').style.display = 'block';
      initAnimations();
    } else {
      const err = document.getElementById('login-err');
      err.style.display = 'block';
      document.getElementById('pw').value = '';
      document.getElementById('pw').focus();
    }
  }

  window.addEventListener('load', () => {
    if (sessionStorage.getItem('aurum_ok') === '1') {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('main').style.display = 'block';
      initAnimations();
    }
  });

  function initAnimations() {
    const els = document.querySelectorAll('.fade-in');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 70);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(el => obs.observe(el));
  }

  function sendForm() {
    const name  = document.getElementById('f-name').value.trim();
    const email = document.getElementById('f-email').value.trim();
    const msg   = document.getElementById('f-msg').value.trim();
    if (!name || !email || !msg) {
      alert('Täytä kaikki kentät ennen lähettämistä.');
      return;
    }
    const subject = encodeURIComponent('Aurum-tiimi: kysymys — ' + name);
    const body    = encodeURIComponent('Nimi: ' + name + '\nSähköposti: ' + email + '\n\nKysymys:\n' + msg);
    window.location.href = 'mailto:digimahis@gmail.com?subject=' + subject + '&body=' + body;
    document.getElementById('form-success').style.display = 'block';
    document.getElementById('f-name').value  = '';
    document.getElementById('f-email').value = '';
    document.getElementById('f-msg').value   = '';
  }
</script>

